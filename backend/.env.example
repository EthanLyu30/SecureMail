# 数据库配置
DATABASE_URL=postgresql://mailuser:mailpass@localhost:5432/maildb

# 应用配置
APP_NAME=智能安全邮箱
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# JWT配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 安全配置
PASSWORD_MIN_LENGTH=6
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=30
SEND_RATE_LIMIT=20

# 附件配置
MAX_ATTACHMENT_SIZE=10485760
ATTACHMENT_DIR=/home/exam/data/attachments

# CORS配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]